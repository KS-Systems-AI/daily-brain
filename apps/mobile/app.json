{
  "expo": {
    "name": "Daily Brain",
    "slug": "daily-brain",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dailybrain",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dailybrain.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio", "fetch"],
        "NSMicrophoneUsageDescription": "Daily Brain benötigt Zugriff auf das Mikrofon für die Spracheingabe von Aufgaben und Notizen.",
        "NSSpeechRecognitionUsageDescription": "Daily Brain nutzt die Spracherkennung, um diktierte Aufgaben und Notizen in Text umzuwandeln.",
        "NSPhotoLibraryUsageDescription": "Daily Brain kann auf deine Fotomediathek zugreifen, wenn du Bilder auswählst oder einfügst (z. B. in Notizen). Der Zugriff erfolgt nur auf deine ausdrückliche Aktion.",
        "NSPhotoLibraryAddUsageDescription": "Daily Brain darf Bilder in deiner Fotomediathek speichern, wenn du z. B. ein Foto aus der App exportierst oder speicherst.",
        "NSCameraUsageDescription": "Daily Brain benötigt Zugriff auf die Kamera, wenn du ein Foto direkt aufnehmen möchtest (z. B. für Notizen)."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.dailybrain.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff"
        }
      ],
      "./modules/dailybrain-intents/plugin/src/index.js",
      "expo-speech-recognition",
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.dailybrain.app.widget",
                  "targetName": "widget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.dailybrain.app"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.dailybrain.app.voicenoteswidget",
                  "targetName": "voice-note-widget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.dailybrain.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "cef9432d-81de-47dc-905c-65b5ac90a195"
      },
      "router": {}
    },
    "owner": "kesc2803"
  }
}
